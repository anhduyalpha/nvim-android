      "\tqueue<int> q;",
      "\tq.push(start);",
      "\tdist[start] = 0;",
      "\twhile(!q.empty()) {",
      "\t\tint u = q.front(); q.pop();",
      "\t\tfor(int v : adj[u]) {",
      "\t\t\tif(dist[v] == -1) {",
      "\t\t\t\tdist[v] = dist[u] + 1;",
      "\t\t\t\tq.push(v);",
      "\t\t\t}",
      "\t\t}",
      "\t}",
      "}$0"
    ]
